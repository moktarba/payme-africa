# ============================================================
# PayMe Africa — Variables d'environnement PRODUCTION
# Copier en .env.prod et remplir les valeurs sur le VPS
# ============================================================

NODE_ENV=production
PORT=4000

# Base de données
DB_HOST=postgres
DB_PORT=5432
DB_USER=payme_prod
DB_PASSWORD=CHANGER_MOT_DE_PASSE_FORT_ICI
DB_NAME=payme_db_prod

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGER_MOT_DE_PASSE_REDIS_ICI

# Auth JWT (générer avec: openssl rand -hex 64)
JWT_SECRET=GENERER_SECRET_256_BITS_ICI
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# OTP SMS — Africa's Talking production
AT_API_KEY=VOTRE_CLE_AFRICASTALKING
AT_USERNAME=paymeafrica
AT_SENDER_ID=PayMe

# Paiements Wave
WAVE_API_KEY=
WAVE_MERCHANT_ID=
WAVE_WEBHOOK_SECRET=

# Paiements Orange Money
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_MERCHANT_ID=

# Paiements Free Money
FREE_MONEY_API_KEY=
FREE_MONEY_MERCHANT_ID=

# Feature flags
FEATURE_WAVE_ENABLED=true
FEATURE_ORANGE_ENABLED=true
FEATURE_FREE_MONEY_ENABLED=true

# CORS (domaines autorisés, séparés par virgules)
CORS_ORIGINS=https://app.paymeafrica.sn,https://paymeafrica.sn

# Logs
LOG_LEVEL=info

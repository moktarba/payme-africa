# Application
NODE_ENV=development
PORT=4000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=payme
DB_PASSWORD=payme_secret
DB_NAME=payme_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change_this_in_production_super_secret_key_256bits
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# OTP / SMS (Africa's Talking)
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=PayMe

# OTP Config
OTP_EXPIRES_MINUTES=5
OTP_LENGTH=6

# Paiements
WAVE_API_KEY=
WAVE_MERCHANT_ID=
WAVE_WEBHOOK_SECRET=

ORANGE_MONEY_API_KEY=
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_WEBHOOK_SECRET=

# Feature flags
FEATURE_WAVE_ENABLED=true
FEATURE_ORANGE_ENABLED=false
FEATURE_FREE_MONEY_ENABLED=false

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,exp://localhost:19000
